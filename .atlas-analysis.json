  "keyFeatures": [
    "Temperature conversions (Celsius, Fahrenheit, Kelvin)",
    "Length conversions (meters, kilometers, miles, feet)",
    "Weight conversions (kilograms, pounds, grams)",
    "Velocity conversions (km/h, mph, m/s)",
    "Real-time conversion as you type",
    "Conversion history tracking",
    "Dark/Light/Auto theme modes",
    "Remote access via ngrok tunneling",
    "Cross-platform support (Windows, macOS, Linux)"
  ],
  "publicApiSurface": [
    "POST /api/convert - Convert units with categoria, valor, desde, hasta",
    "GET /api/unidades/<categoria> - Get available units for a category",
    "GET /api/status - Check ICE server connection status",
    "convertirTemperatura(valor, desde, hasta) - ICE method for temperature conversion",
    "convertirLongitud(valor, desde, hasta) - ICE method for length conversion",
    "convertirPeso(valor, desde, hasta) - ICE method for weight conversion",
    "convertirVelocidad(valor, desde, hasta) - ICE method for velocity conversion",
    "unidadesDisponibles(categoria) - ICE method to list available units"
  ]
}
